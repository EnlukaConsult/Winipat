{
  "version": 2,
  "framework": "nextjs",
  "buildCommand": "npm run build",
  "outputDirectory": ".next",
  "crons": [
    {
      "path": "/api/cron/auto-release",
      "schedule": "15 * * * *"
    },
    {
      "path": "/api/cron/sla-escalation",
      "schedule": "*/30 * * * *"
    },
    {
      "path": "/api/cron/trust-scores",
      "schedule": "30 3 * * *"
    },
    {
      "path": "/api/cron/track-shipments",
      "schedule": "*/30 * * * *"
    }
  ]
}
